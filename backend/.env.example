DATABASE_URL=postgresql://reportal:reportal_dev_password@localhost:5432/taskflow?schema=public
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here
TOKEN_HASH_SECRET=your-api-token-hash-secret-here
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
PORT=3000

# In-app feedback routing. When TASKFLOW_PRODUCT_PROJECT_ORG_ID is set, every
# feedback submission also creates a Task in the named project (resolved by
# org_id + project key) on the matching flow (BUG -> bug, FEATURE -> feature,
# IMPROVEMENT -> improvement). When unset, feedback is stored without an
# associated task.
TASKFLOW_PRODUCT_PROJECT_ORG_ID=
TASKFLOW_PRODUCT_PROJECT_KEY=TF
