generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  members     OrgMember[]
  teams       Team[]
  projects    Project[]
  flows       Flow[]
  apiTokens   ApiToken[]
  appSettings AppSetting[]
  feedback    Feedback[]
  invitations Invitation[]

  @@map("organizations")
}

model Invitation {
  id                String    @id @default(uuid()) @db.Uuid
  orgId             String    @map("org_id") @db.Uuid
  email             String
  role              String // owner, admin, member
  tokenHash         String?   @unique @map("token_hash")
  invitedById       String?   @map("invited_by_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz()
  acceptedAt        DateTime? @map("accepted_at") @db.Timestamptz()
  acceptedByUserId  String?   @map("accepted_by_user_id") @db.Uuid
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz()
  revokedById       String?   @map("revoked_by_id") @db.Uuid

  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy      User?        @relation("InvitationInvitedBy", fields: [invitedById], references: [id])
  acceptedByUser User?        @relation("InvitationAcceptedBy", fields: [acceptedByUserId], references: [id])
  revokedBy      User?        @relation("InvitationRevokedBy", fields: [revokedById], references: [id])

  @@index([orgId, email])
  @@index([email])
  @@map("invitations")
}

model OrgMember {
  orgId     String   @map("org_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String // owner, admin, member
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id])

  @@id([orgId, userId])
  @@index([userId])
  @@map("org_members")
}

model Team {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  name        String
  slug        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  org      Organization  @relation(fields: [orgId], references: [id])
  members  UserTeam[]
  projects ProjectTeam[]

  @@unique([orgId, slug])
  @@unique([orgId, name])
  @@map("teams")
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  email       String?  @unique
  displayName String   @map("display_name")
  actorType   String   @map("actor_type") // human, agent, system
  status      String   @default("active") // active, deactivated
  timezone    String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  teams             UserTeam[]
  oauthConnections  OauthConnection[]
  createdTasks      Task[]                         @relation("TaskCreatedBy")
  assignedTasks     Task[]                         @relation("TaskAssignee")
  taskTransitions   TaskTransition[]
  reassignedBy      TaskTransition[]               @relation("TaskTransitionNewAssignee")
  comments          Comment[]
  ownedProjects     Project[]                      @relation("ProjectOwner")
  defaultOnProjects Project[]                      @relation("ProjectDefaultAssignee")
  defaultOnStatuses ProjectStatusDefaultAssignee[]
  apiTokens         ApiToken[]
  orgMemberships    OrgMember[]
  feedback            Feedback[]
  invitationsSent     Invitation[]      @relation("InvitationInvitedBy")
  invitationsAccepted Invitation[]      @relation("InvitationAcceptedBy")
  invitationsRevoked  Invitation[]      @relation("InvitationRevokedBy")

  @@map("users")
}

model UserTeam {
  userId    String   @map("user_id") @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  isPrimary Boolean  @default(false) @map("is_primary")
  grantedBy String?  @map("granted_by") @db.Uuid
  grantedAt DateTime @default(now()) @map("granted_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id])

  @@id([userId, teamId])
  @@index([userId])
  @@index([teamId])
  @@map("user_teams")
}

model OauthConnection {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  provider       String // google
  providerUserId String    @map("provider_user_id")
  lastUsedAt     DateTime? @map("last_used_at") @db.Timestamptz()
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, provider])
  @@unique([provider, providerUserId])
  @@map("oauth_connections")
}

model Flow {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  slug        String
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  org               Organization     @relation(fields: [orgId], references: [id])
  statuses          FlowStatus[]
  transitions       FlowTransition[]
  tasks             Task[]
  defaultOnProjects Project[]
  appSettings       AppSetting[]
  projectFlows      ProjectFlow[]

  @@index([orgId, slug])
  @@map("flows")
}

model FlowStatus {
  id          String   @id @default(uuid()) @db.Uuid
  flowId      String   @map("flow_id") @db.Uuid
  slug        String
  name        String
  description String?
  sortOrder   Int      @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  flow            Flow                           @relation(fields: [flowId], references: [id])
  transitionsFrom FlowTransition[]               @relation("TransitionFrom")
  transitionsTo   FlowTransition[]               @relation("TransitionTo")
  tasksAtStatus   Task[]
  transitionFrom  TaskTransition[]               @relation("TaskTransitionFrom")
  transitionTo    TaskTransition[]               @relation("TaskTransitionTo")
  projectDefaults ProjectStatusDefaultAssignee[]

  @@unique([flowId, slug])
  @@index([flowId, sortOrder])
  @@map("flow_statuses")
}

model FlowTransition {
  id           String @id @default(uuid()) @db.Uuid
  flowId       String @map("flow_id") @db.Uuid
  fromStatusId String @map("from_status_id") @db.Uuid
  toStatusId   String @map("to_status_id") @db.Uuid

  flow       Flow       @relation(fields: [flowId], references: [id])
  fromStatus FlowStatus @relation("TransitionFrom", fields: [fromStatusId], references: [id])
  toStatus   FlowStatus @relation("TransitionTo", fields: [toStatusId], references: [id])

  @@unique([flowId, fromStatusId, toStatusId])
  @@map("flow_transitions")
}

model Task {
  id              String    @id @default(uuid()) @db.Uuid
  displayId       String    @unique @map("display_id")
  flowId          String    @map("flow_id") @db.Uuid
  currentStatusId String    @map("current_status_id") @db.Uuid
  title           String
  description     String?   @db.Text
  priority        String    @default("medium") // critical, high, medium, low
  resolution      String? // fixed, invalid, duplicate, wont_fix, cannot_reproduce, completed, rejected, deferred
  createdBy       String    @map("created_by") @db.Uuid
  assigneeId      String?   @map("assignee_id") @db.Uuid
  dueDate         DateTime? @map("due_date") @db.Date
  isDeleted       Boolean   @default(false) @map("is_deleted")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  flow          Flow             @relation(fields: [flowId], references: [id])
  currentStatus FlowStatus       @relation(fields: [currentStatusId], references: [id])
  creator       User             @relation("TaskCreatedBy", fields: [createdBy], references: [id])
  assignee      User?            @relation("TaskAssignee", fields: [assigneeId], references: [id])
  transitions   TaskTransition[]
  comments      Comment[]
  projects      TaskProject[]
  commits       TaskCommit[]
  pullRequests  TaskPullRequest[]

  @@index([flowId, currentStatusId])
  @@index([assigneeId])
  @@index([createdBy])
  @@index([dueDate])
  @@map("tasks")
}

model TaskTransition {
  id            String   @id @default(uuid()) @db.Uuid
  taskId        String   @map("task_id") @db.Uuid
  fromStatusId  String?  @map("from_status_id") @db.Uuid
  toStatusId    String   @map("to_status_id") @db.Uuid
  actorId       String   @map("actor_id") @db.Uuid
  note          String   @db.Text
  actorType     String   @map("actor_type") // human, agent, system
  newAssigneeId String?  @map("new_assignee_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  task        Task        @relation(fields: [taskId], references: [id])
  fromStatus  FlowStatus? @relation("TaskTransitionFrom", fields: [fromStatusId], references: [id])
  toStatus    FlowStatus  @relation("TaskTransitionTo", fields: [toStatusId], references: [id])
  actor       User        @relation(fields: [actorId], references: [id])
  newAssignee User?       @relation("TaskTransitionNewAssignee", fields: [newAssigneeId], references: [id])

  @@index([taskId, createdAt])
  @@index([actorType, taskId])
  @@map("task_transitions")
}

model Project {
  id                    String    @id @default(uuid()) @db.Uuid
  orgId                 String    @map("org_id") @db.Uuid
  key                   String
  name                  String
  ownerUserId           String    @map("owner_user_id") @db.Uuid
  defaultAssigneeUserId String?   @map("default_assignee_user_id") @db.Uuid
  defaultFlowId         String?   @map("default_flow_id") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  archivedAt            DateTime? @map("archived_at") @db.Timestamptz()

  org             Organization                   @relation(fields: [orgId], references: [id])
  owner           User                           @relation("ProjectOwner", fields: [ownerUserId], references: [id])
  defaultAssignee User?                          @relation("ProjectDefaultAssignee", fields: [defaultAssigneeUserId], references: [id])
  defaultFlow     Flow?                          @relation(fields: [defaultFlowId], references: [id])
  teams           ProjectTeam[]
  tasks           TaskProject[]
  flows           ProjectFlow[]
  statusDefaults  ProjectStatusDefaultAssignee[]
  repositories    ProjectRepository[]

  @@unique([orgId, key])
  @@index([ownerUserId])
  @@index([archivedAt])
  @@map("projects")
}

enum RepoProvider {
  GITHUB

  @@map("repo_provider")
}

model ProjectRepository {
  id        String       @id @default(uuid()) @db.Uuid
  projectId String       @map("project_id") @db.Uuid
  provider  RepoProvider
  owner     String
  name      String
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  commits      TaskCommit[]
  pullRequests TaskPullRequest[]

  @@unique([projectId, provider, owner, name])
  @@index([projectId])
  @@map("project_repositories")
}

model TaskCommit {
  id           String    @id @default(uuid()) @db.Uuid
  taskId       String    @map("task_id") @db.Uuid
  repositoryId String    @map("repository_id") @db.Uuid
  sha          String
  message      String?   @db.Text
  author       String?
  authoredAt   DateTime? @map("authored_at") @db.Timestamptz()
  url          String
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  task       Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  repository ProjectRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, sha])
  @@index([taskId])
  @@map("task_commits")
}

model TaskPullRequest {
  id           String    @id @default(uuid()) @db.Uuid
  taskId       String    @map("task_id") @db.Uuid
  repositoryId String    @map("repository_id") @db.Uuid
  number       Int
  title        String?
  state        String // open, closed, merged
  author       String?
  mergedAt     DateTime? @map("merged_at") @db.Timestamptz()
  url          String
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz()

  task       Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  repository ProjectRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, number])
  @@index([taskId])
  @@map("task_pull_requests")
}

model ProjectFlow {
  projectId String   @map("project_id") @db.Uuid
  flowId    String   @map("flow_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  flow    Flow    @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@id([projectId, flowId])
  @@index([flowId])
  @@map("project_flows")
}

model ProjectTeam {
  projectId String @map("project_id") @db.Uuid
  teamId    String @map("team_id") @db.Uuid

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team    Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([projectId, teamId])
  @@index([teamId])
  @@map("project_teams")
}

model TaskProject {
  taskId    String   @map("task_id") @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([taskId, projectId])
  @@index([projectId])
  @@map("task_projects")
}

model ProjectStatusDefaultAssignee {
  projectId    String @map("project_id") @db.Uuid
  flowStatusId String @map("flow_status_id") @db.Uuid
  userId       String @map("user_id") @db.Uuid

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  flowStatus FlowStatus @relation(fields: [flowStatusId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@id([projectId, flowStatusId])
  @@index([flowStatusId])
  @@index([userId])
  @@map("project_status_default_assignees")
}

model AppSetting {
  orgId         String   @id @map("org_id") @db.Uuid
  defaultFlowId String?  @map("default_flow_id") @db.Uuid
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  defaultFlow Flow?        @relation(fields: [defaultFlowId], references: [id])

  @@map("app_settings")
}

model ApiToken {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash")
  name        String
  integration Boolean   @default(false)
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz()
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz()

  org    Organization    @relation(fields: [orgId], references: [id])
  user   User            @relation(fields: [userId], references: [id])
  scopes ApiTokenScope[]

  @@index([orgId])
  @@index([userId])
  @@map("api_tokens")
}

model Scope {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tokens ApiTokenScope[]

  @@map("scopes")
}

model ApiTokenScope {
  tokenId String @map("token_id") @db.Uuid
  scopeId String @map("scope_id") @db.Uuid

  token ApiToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  scope Scope    @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@id([tokenId, scopeId])
  @@index([scopeId])
  @@map("api_token_scopes")
}

model Feedback {
  id         String    @id @default(uuid()) @db.Uuid
  orgId      String    @map("org_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  type       String // BUG, ENHANCEMENT
  message    String    @db.Text
  page       String?
  adminNotes String?   @map("admin_notes") @db.Text
  archivedAt DateTime? @map("archived_at") @db.Timestamptz()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@map("feedback")
}

model Comment {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  body      String   @db.Text
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  task   Task @relation(fields: [taskId], references: [id])
  author User @relation(fields: [authorId], references: [id])

  @@index([taskId, createdAt])
  @@map("comments")
}
